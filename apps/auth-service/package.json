{
  "name": "auth-service",
  "version": "1.0.0",
  "description": "Servicio de Autenticación y Contactos para clon de WhatsApp",
  "main": "dist/main.js",
  "type": "module",
  "prisma": {
    "schema": "./src/infrastructure/database/prisma/schema.prisma"
  },
  "scripts": {
    "prebuild": "npx prisma generate --schema=./src/infrastructure/database/prisma/schema.prisma",
    "build": "tsup src/main.ts --format esm --clean --minify",
    "start": "node div/main.js",
    "dev": "ts-node-dev --respawn --transpile-only src/main.js",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:studio": "npx prisma studio"
  },
  "dependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@prisma/client": "^5.22.0",
    "@types/cors": "^2.8.19",
    "argon2": "^0.44.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.22.2",
    "jsonwebtoken": "^9.0.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.30",
    "prisma": "^5.22.0",
    "ts-node-dev": "^2.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.4.3"
  }
}
