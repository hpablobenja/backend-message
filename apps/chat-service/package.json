{
  "name": "chat-service",
  "version": "1.0.0",
  "description": "Servicio de Mensajería en Tiempo Real, Persistencia NoSQL y Escalabilidad con Redis",
  "main": "dist/main.js",
  "type": "module",
  "scripts": {
    "build": "tsup src/main.ts --format esm --clean --minify",
    "start": "node dist/main.js",
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "ioredis": "^5.4.1",
    "mongoose": "^8.2.2",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.7.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "ts-node-dev": "^2.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.4.3"
  }
}
